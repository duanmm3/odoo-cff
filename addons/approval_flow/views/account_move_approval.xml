<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 发票列表视图扩展 -->
    <record id="view_account_move_approval_tree" model="ir.ui.view">
        <field name="name">account.move.approval.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" optional="show" widget="badge" decoration-success="approval_state=='approved'" decoration-warning="approval_state=='pending'" decoration-danger="approval_state=='rejected'"/>
                <field name="need_approval" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- 供应商账单列表视图扩展 -->
    <record id="view_account_move_approval_tree_vendor" model="ir.ui.view">
        <field name="name">account.move.approval.tree.vendor</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" optional="show" widget="badge" decoration-success="approval_state=='approved'" decoration-warning="approval_state=='pending'" decoration-danger="approval_state=='rejected'"/>
                <field name="need_approval" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- 发票表单视图扩展 -->
    <record id="view_account_move_approval_form" model="ir.ui.view">
        <field name="name">account.move.approval.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- 审批按钮 - 管理员在待审批状态可见 -->
            <xpath expr="//header" position="inside">
                <button name="action_approve_invoice" string="审批通过" type="object" 
                    invisible="approval_state != 'pending'" 
                    class="oe_highlight" groups="base.group_system"/>
            </xpath>
            
            <!-- 审批状态显示 -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" widget="badge" decoration-success="approval_state=='approved'" decoration-warning="approval_state=='pending'" decoration-danger="approval_state=='rejected'" readonly="1"/>
            </xpath>
            
            <!-- 添加审批信息到页面 -->
            <xpath expr="//field[@name='partner_id']/ancestor::group[1]" position="inside">
                <field name="need_approval" invisible="1"/>
                <field name="approval_user_id" invisible="approval_state == 'draft'"/>
                <field name="approval_date" invisible="approval_state == 'draft'"/>
                <field name="approval_request_id" invisible="approval_state == 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>