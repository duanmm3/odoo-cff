<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 审批请求列表视图 -->
    <record id="view_approval_request_list" model="ir.ui.view">
        <field name="name">approval.request.list</field>
        <field name="model">approval.request</field>
        <field name="arch" type="xml">
            <list string="审批请求" decoration-success="state=='approved'" decoration-danger="state=='rejected'" decoration-warning="state=='pending'" sample="1">
                <field name="name"/>
                <field name="category_id"/>
                <field name="requester_id"/>
                <field name="approver_id"/>
                <field name="amount" widget="monetary"/>
                <field name="state" widget="badge" decoration-success="state=='approved'" decoration-danger="state=='rejected'" decoration-warning="state=='pending'"/>
                <button name="action_approve" string="✓ 通过" type="object" class="btn-success" invisible="state != 'pending'" title="通过"/>
                <button name="action_reject" string="✗ 拒绝" type="object" class="btn-danger" invisible="state != 'pending'" title="拒绝"/>
            </list>
        </field>
    </record>

    <!-- 审批请求表单视图 -->
    <record id="view_approval_request_form" model="ir.ui.view">
        <field name="name">approval.request.form</field>
        <field name="model">approval.request</field>
        <field name="arch" type="xml">
            <form string="审批请求">
                <header>
                    <button name="action_approve" string="✓ 通过" type="object" invisible="state != 'pending'" class="oe_highlight o_btn Approve" style="background-color: #28a745; color: white; font-weight: bold;"/>
                    <button name="action_reject" string="✗ 拒绝" type="object" invisible="state != 'pending'" class="oe_highlight o_btn_reject" style="background-color: #dc3545; color: white; font-weight: bold;"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1" options="{'font': {'weight': 'bold'}}" style="font-size: 16px;"/>
                            <field name="category_id" readonly="state != 'draft'" options="{'bg_color': '#e8f4f8'}"/>
                            <field name="requester_id" readonly="state != 'draft'"/>
                            <field name="approver_id" readonly="state != 'draft'"/>
                            <field name="amount" widget="monetary" options="{'currency_field': 'company_id'}" readonly="state != 'draft'" style="font-size: 18px; font-weight: bold; color: #007bff;"/>
                        </group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="关联单据" col="4">
                        <field name="sale_order_id" readonly="1" options="{'bg_color': '#f8f9fa'}"/>
                        <field name="purchase_order_id" readonly="1" options="{'bg_color': '#f8f9fa'}"/>
                        <field name="account_move_id" readonly="1" options="{'bg_color': '#f8f9fa'}"/>
                        <field name="account_payment_id" readonly="1" options="{'bg_color': '#f8f9fa'}"/>
                    </group>
                    <group string="申请说明">
                        <field name="note" readonly="state != 'draft'" placeholder="请输入申请说明..." options="{'autosize': true}"/>
                    </group>
                    <group string="拒绝原因" invisible="state != 'rejected'">
                        <field name="reject_reason" readonly="1" options="{'bg_color': '#fff3cd'}"/>
                    </group>
                    <group string="审批结果" col="2">
                        <field name="date_approved" readonly="1" invisible="state != 'approved'" options="{'bg_color': '#d4edda'}"/>
                        <field name="date_rejected" readonly="1" invisible="state != 'rejected'" options="{'bg_color': '#f8d7da'}"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- 审批请求搜索视图 -->
    <record id="view_approval_request_search" model="ir.ui.view">
        <field name="name">approval.request.search</field>
        <field name="model">approval.request</field>
        <field name="arch" type="xml">
            <search string="搜索审批请求">
                <field name="name"/>
                <field name="requester_id"/>
                <field name="approver_id"/>
                <filter string="待审批" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="已批准" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="已拒绝" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="按审批类型分组" name="group_category" context="{'group_by': 'category_id'}"/>
                <filter string="按状态分组" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- 审批请求动作 -->
    <record id="action_approval_request" model="ir.actions.act_window">
        <field name="name">审批请求</field>
        <field name="res_model">approval.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无审批请求
            </p>
        </field>
    </record>

    <!-- 审批类别列表视图 -->
    <record id="view_approval_category_list" model="ir.ui.view">
        <field name="name">approval.category.list</field>
        <field name="model">approval.category</field>
        <field name="arch" type="xml">
            <list string="审批类型">
                <field name="name"/>
                <field name="code"/>
                <field name="approval_limit"/>
            </list>
        </field>
    </record>

    <!-- 审批类别表单视图 -->
    <record id="view_approval_category_form" model="ir.ui.view">
        <field name="name">approval.category.form</field>
        <field name="model">approval.category</field>
        <field name="arch" type="xml">
            <form string="审批类型">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="approval_limit"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 审批类别动作 -->
    <record id="action_approval_category" model="ir.actions.act_window">
        <field name="name">审批类型</field>
        <field name="res_model">approval.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 审批菜单 -->
    <menuitem id="menu_approval_root" name="审批" sequence="100" web_icon="approval_flow,static/description/icon.png"/>
    <menuitem id="menu_approval_request" name="审批请求" parent="menu_approval_root" action="action_approval_request" sequence="1"/>
    <menuitem id="menu_approval_category" name="审批类型" parent="menu_approval_root" action="action_approval_category" sequence="2"/>
</odoo>
