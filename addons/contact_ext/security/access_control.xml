<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ACL for res.partner - Admin -->
        <record id="access_res_partner_admin" model="ir.model.access">
            <field name="name">res.partner.admin</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="group_id" ref="base.group_erp_manager"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- ACL for res.partner - Employee group -->
        <record id="access_res_partner_employee" model="ir.model.access">
            <field name="name">res.partner.employee</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- ACL for res.users - Employee group -->
        <record id="access_res_users_employee" model="ir.model.access">
            <field name="name">res.users.employee</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>
    </data>
</odoo>
