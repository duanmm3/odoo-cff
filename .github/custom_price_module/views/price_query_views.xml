<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view for price queries -->
    <record id="view_price_query_list" model="ir.ui.view">
        <field name="name">price.query.list</field>
        <field name="model">price.query</field>
        <field name="arch" type="xml">
            <list string="Price Queries">
                <field name="name" string="IC Model"/>
                <field name="query_count" string="Query Count"/>
                <field name="best_price" string="Best Price (RMB)"/>
                <field name="best_supplier" string="Best Supplier"/>
                <field name="total_quotes" string="Total Quotes"/>
                <field name="last_query_time" string="Last Query"/>
            </list>
        </field>
    </record>

    <!-- Form view for price queries -->
    <record id="view_price_query_form" model="ir.ui.view">
        <field name="name">price.query.form</field>
        <field name="model">price.query</field>
        <field name="arch" type="xml">
            <form string="Price Query">
                <header>
                    <button name="action_query_price" type="object" string="Query Price Now" class="btn-primary"/>
                    <button name="action_view_history" type="object" string="View History" class="btn-secondary"/>
                    <button name="action_clear_cache" type="object" string="Clear Cache" class="btn-warning"/>
                    <field name="is_active" widget="boolean_button" options='{"terminology": "active"}'/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_query_price" type="object" string="Query Price" class="oe_stat_button" icon="fa-search">
                            <field name="query_count" widget="statinfo" string="Queries"/>
                        </button>
                        <button name="action_view_history" type="object" string="History" class="oe_stat_button" icon="fa-history">
                            <field name="total_quotes" widget="statinfo" string="Total Quotes"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Enter IC Model (e.g., STM32F103C8T6)"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="query_count"/>
                            <field name="best_price"/>
                            <field name="best_supplier"/>
                            <field name="total_quotes"/>
                        </group>
                        <group>
                            <field name="query_date"/>
                            <field name="last_query_time"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Query Result">
                            <field name="last_query_result" widget="json_widget"/>
                        </page>
                        <page string="Configuration">
                            <group>
                                <group>
                                    <field name="mouser_api_key" password="True"/>
                                    <field name="nexar_client_id"/>
                                    <field name="nexar_client_secret" password="True"/>
                                </group>
                                <group>
                                    <field name="oemsecrets_api_key" password="True"/>
                                    <field name="qwen_api_key" password="True"/>
                                </group>
                            </group>
                            <group string="Redis Configuration">
                                <group>
                                    <field name="redis_host"/>
                                    <field name="redis_port"/>
                                </group>
                                <group>
                                    <field name="redis_password" password="True"/>
                                    <field name="redis_db"/>
                                </group>
                            </group>
                            <group string="Exchange Rate Configuration">
                                <field name="exchange_api_url"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view for price queries -->
    <record id="view_price_query_search" model="ir.ui.view">
        <field name="name">price.query.search</field>
        <field name="model">price.query</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="best_supplier"/>
                <filter name="active" string="Active" domain="[('is_active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter name="today" string="Today" domain="[('query_date', '>=', context_today())]"/>
                <filter name="this_week" string="This Week" domain="[('query_date', '>=', context_today().replace(days=-7))]"/>
                <group>
                    <filter name="group_name" string="IC Model" context="{'group_by': 'name'}"/>
                    <filter name="group_supplier" string="Best Supplier" context="{'group_by': 'best_supplier'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for price queries -->
    <record id="action_price_query" model="ir.actions.act_window">
        <field name="name">Price Queries</field>
        <field name="res_model">price.query</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No price queries yet.
            </p>
            <p>
                Create a new price query to search for electronic component prices from multiple suppliers.
            </p>
        </field>
    </record>

</odoo>